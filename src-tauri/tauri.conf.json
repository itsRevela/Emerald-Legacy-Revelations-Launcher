{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Emerald Legacy Revelations",
  "version": "0.2.0",
  "identifier": "com.emerald.legacy.revelations",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Emerald Legacy Revelations",
        "width": 1000,
        "height": 650,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Visible",
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
